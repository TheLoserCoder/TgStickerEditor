{
  "appId": "com.tgstickereditor.app",
  "productName": "TgStickerEditor",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-main/**/*",
    "dist-renderer/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "node_modules/sharp",
      "to": "app.asar.unpacked/node_modules/sharp",
      "filter": ["**/*"]
    },
    {
      "from": "node_modules/ffmpeg-static",
      "to": "app.asar.unpacked/node_modules/ffmpeg-static",
      "filter": ["**/*"]
    }
  ],
  "asarUnpack": [
    "node_modules/sharp/**/*",
    "node_modules/ffmpeg-static/**/*"
  ],
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "category": "Graphics"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  }
}
