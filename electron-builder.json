{
  "appId": "com.tgstickereditor.app",
  "productName": "TgStickerEditor",
  "asar": true,
  "publish": {
    "provider": "github",
    "owner": "TheLoserCoder",
    "repo": "TgStickerEditor",
    "releaseType": "release",
    "publishAutoUpdate": true
  },
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist-main/**/*",
    "dist-renderer/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "node_modules/sharp",
      "to": "app.asar.unpacked/node_modules/sharp",
      "filter": ["**/*"]
    },
    {
      "from": "node_modules/ffmpeg-static",
      "to": "app.asar.unpacked/node_modules/ffmpeg-static",
      "filter": ["**/*"]
    }
  ],
  "asarUnpack": [
    "node_modules/sharp/**/*",
    "node_modules/ffmpeg-static/**/*",
    "node_modules/@img/**/*"
  ],
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "category": "Graphics",
    "icon": "build/icon_linux.png"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon_windows.ico"
  }
}
