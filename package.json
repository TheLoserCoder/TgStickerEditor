{
  "name": "tgstickereditor",
  "version": "1.0.0",
  "description": "Telegram Sticker Editor - Electron App",
  "main": "dist-main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"vite\" \"npm run dev:electron\"",
    "dev:electron": "vite --config vite.main.config.ts build && vite --config vite.preload.config.ts build && electron . --trace-warnings",
    "build": "vite build && vite --config vite.preload.config.ts build && vite --config vite.main.config.ts build",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.json --publish always",
    "build:win": "npm run build && electron-builder --win --config electron-builder.json --publish always",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.json --publish always",
    "test": "jest"
  },
  "keywords": [
    "electron",
    "telegram",
    "sticker",
    "editor"
  ],
  "author": {
    "name": "TgStickerEditor",
    "email": "dev@tgstickereditor.com"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "jest": "^30.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.1.6",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "electron-store": "^11.0.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "grammy": "^1.40.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0",
    "sharp": "^0.34.5",
    "uniqueid": "^1.0.0"
  }
}
